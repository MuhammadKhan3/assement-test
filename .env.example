# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (via Prisma)
DATABASE_URL="postgresql://flashdeal:flashdeal_secret@localhost:5433/flashdeal_db"

# Redis
REDIS_URL="redis://localhost:6379"

# Reservation TTL in seconds (600 = 10 minutes)
RESERVATION_TTL_SECONDS=600

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
